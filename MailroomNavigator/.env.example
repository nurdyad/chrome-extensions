# -----------------------------------------------------------------------------
# MailroomNavigator local automation template
# Copy this file to .env and fill in real values on each machine.
# Do not commit the real .env file.
# -----------------------------------------------------------------------------

# BetterLetter login used by save-auth-local.mjs
user_email=your.email@example.com
user_password=replace_with_real_password

# Admin panel HTTP auth (if your environment requires it)
ADMIN_PANEL_USERNAME=
ADMIN_PANEL_PASSWORD=
# Optional alias keys accepted by scripts:
# BASIC_AUTH_USERNAME=
# BASIC_AUTH_PASSWORD=

# IMAP mailbox used to read BetterLetter OTP codes
OTP_EMAIL_IMAP_HOST=imap.example.com
OTP_EMAIL_IMAP_PORT=993
OTP_EMAIL_IMAP_SECURE=true
OTP_EMAIL_USERNAME=otp-mailbox@example.com
OTP_EMAIL_PASSWORD=replace_with_real_imap_password
OTP_EMAIL_MAILBOX=INBOX
OTP_EMAIL_FROM_FILTER=
OTP_EMAIL_SUBJECT_FILTER=security code
OTP_EMAIL_LOOKBACK_MINUTES=20
OTP_EMAIL_TIMEOUT_SECONDS=120
OTP_EMAIL_POLL_SECONDS=4
OTP_EMAIL_CODE_REGEX=\\b(\\d{6})\\b
OTP_EMAIL_ACCEPT_SKEW_SECONDS=60

# Save-auth behavior
AUTH_HEADLESS=1
AUTO_2FA_FROM_EMAIL=1
DASHBOARD_WAIT_SECONDS=120
POST_LOGIN_WAIT_SECONDS=120
POST_OTP_WAIT_SECONDS=35
OTP_SUBMIT_MAX_ATTEMPTS=3
OTP_RELOGIN_MAX_CYCLES=3

# Morning login automation tuning (optional)
MORNING_LOGIN_WINDOW_START_HOUR=7
MORNING_LOGIN_WINDOW_END_HOUR=17
MORNING_LOGIN_ANCHOR_HOUR=7
MORNING_LOGIN_HEARTBEAT_SECONDS=300
MORNING_LOGIN_SAVE_AUTH_MAX_ATTEMPTS=3
MORNING_LOGIN_SAVE_AUTH_RETRY_DELAY_SECONDS=12
MORNING_LOGIN_SAVE_AUTH_TIMEOUT_SECONDS=420
MORNING_LOGIN_VERIFY_TIMEOUT_SECONDS=240
MORNING_LOGIN_DASHBOARD_SUMMARY_TIMEOUT_SECONDS=160

# Global hotkey daemon (macOS)
MAILROOM_HOTKEY_COOLDOWN_SECONDS=2.0

# Local linear trigger server (optional)
LINEAR_TRIGGER_SERVER_HOST=127.0.0.1
LINEAR_TRIGGER_SERVER_PORT=4817
LINEAR_TRIGGER_BOT_JOBS_DIR=
LINEAR_TRIGGER_BOT_JOBS_ENTRY=bot-jobs.js
LINEAR_TRIGGER_BOT_JOBS_ENV_FILE=
LINEAR_TRIGGER_ALLOWED_ORIGINS=
LINEAR_TRIGGER_ALLOW_NO_ORIGIN=1

# Linear issue creation from extension (required for "Create Linear Issue")
LINEAR_API_KEY=
# Team key (short code shown in issue IDs, e.g. SUPP for SUPP-1762)
LINEAR_TEAM_KEY=SUPP
# Optional fallback when panel priority is "No priority" (0/1/2/3/4)
LINEAR_ISSUE_DEFAULT_PRIORITY=0
# Optional Slack sync for Linear issue creation (required only if Slack notify is enabled in panel)
SLACK_BOT_TOKEN=
# Slack sync list scope (1 = only channels bot is already a member of, 0 = list all visible channels)
SLACK_SYNC_MEMBER_ONLY=1

# Optional Access Control Slack alerts
# Access Control is stored locally in a JSON file; Slack is used only for alerts
MAILROOMNAV_ACCESS_CONTROL_STATE_FILE=
# Optional shared key for cross-machine Access Control when exposing the access service remotely.
# Local loopback requests do not need this key; remote clients should send it in the Access Service config.
MAILROOMNAV_ACCESS_CONTROL_SHARED_KEY=
# Target can be a channel/user ID or a channel name without the leading #
MAILROOMNAV_ACCESS_CONTROL_SLACK_TARGET_TYPE=channel
MAILROOMNAV_ACCESS_CONTROL_SLACK_TARGET=
# Backward-compatible aliases also accepted by the server:
# MAILROOMNAV_ACCESS_CONTROL_ALERT_TARGET_TYPE=
# MAILROOMNAV_ACCESS_CONTROL_ALERT_TARGET=
MAILROOMNAV_ACCESS_CONTROL_ALERT_COOLDOWN_MINUTES=60
